{
  "name": "rappi-store-availability",
  "version": "1.0.0",
  "private": true,
  "description": "Rappi Store Availability Intelligence Dashboard — RappiMakers 2026",
  "scripts": {
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "pipeline": "cd data-pipeline && python3 etl.py",
    "build": "cd frontend && npm run build",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
